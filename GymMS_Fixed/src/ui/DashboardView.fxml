<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.DashboardController"
            styleClass="root-pane"
            prefWidth="1280" prefHeight="760">

    <!-- SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" prefWidth="230" spacing="4">
            <padding><Insets top="0" bottom="20" left="0" right="0"/></padding>

            <VBox styleClass="sidebar-logo" alignment="CENTER" spacing="4">
                <padding><Insets top="24" bottom="24" left="20" right="20"/></padding>
                <Label text="💪  FitPro GMS" styleClass="sidebar-brand"/>
                <HBox alignment="CENTER" spacing="6">
                    <Label text="●" style="-fx-text-fill:#4ade80;-fx-font-size:8px;"/>
                    <Label fx:id="roleLabel" text="Admin" styleClass="sidebar-role"/>
                </HBox>
            </VBox>

            <Label text="NAVIGATION" styleClass="sidebar-section-label">
                <padding><Insets top="10" bottom="4" left="20" right="0"/></padding>
            </Label>

            <Button fx:id="btnDashboard" text="⬛  Dashboard"
                    styleClass="sidebar-btn,sidebar-btn-active"
                    onAction="#showDashboardHome"
                    maxWidth="1.7976931348623157E308"/>
            <Button fx:id="btnMembers"   text="👥  Members"
                    styleClass="sidebar-btn"
                    onAction="#showMembers"
                    maxWidth="1.7976931348623157E308"/>
            <Button fx:id="btnTrainers"  text="🏋  Trainers"
                    styleClass="sidebar-btn"
                    onAction="#showTrainers"
                    maxWidth="1.7976931348623157E308"/>
            <Button fx:id="btnWorkouts"  text="⚡  Workouts"
                    styleClass="sidebar-btn"
                    onAction="#showWorkouts"
                    maxWidth="1.7976931348623157E308"/>
            <Button fx:id="btnSchedule"  text="📅  Schedule"
                    styleClass="sidebar-btn"
                    onAction="#showSchedule"
                    maxWidth="1.7976931348623157E308"/>

            <Region VBox.vgrow="ALWAYS"/>
            <Separator styleClass="sidebar-sep"/>
            <Button fx:id="btnLogout" text="🚪  Logout"
                    styleClass="sidebar-btn,sidebar-logout-btn"
                    onAction="#handleLogout"
                    maxWidth="1.7976931348623157E308"/>
        </VBox>
    </left>

    <!-- MAIN AREA — FIX: VBox.vgrow=ALWAYS so it fills the BorderPane center -->
    <center>
        <VBox VBox.vgrow="ALWAYS">

            <!-- TOP HEADER -->
            <HBox styleClass="top-header" alignment="CENTER_LEFT" spacing="20"
                  minHeight="65" maxHeight="65">
                <padding><Insets top="0" bottom="0" left="28" right="28"/></padding>
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label fx:id="welcomeLabel" text="Welcome!" styleClass="header-welcome"/>
                    <Label text="Here's what's happening at your gym today." styleClass="header-sub"/>
                </VBox>
            </HBox>

            <!-- STATS CARDS -->
            <HBox spacing="18" styleClass="stats-bar" minHeight="110" maxHeight="110">
                <padding><Insets top="16" bottom="16" left="28" right="28"/></padding>
                <VBox styleClass="stat-card,stat-card-blue"   HBox.hgrow="ALWAYS" spacing="6">
                    <Label text="Total Members"       styleClass="stat-label"/>
                    <Label fx:id="statMembers"  text="0" styleClass="stat-value"/>
                    <Label text="👥 Registered"        styleClass="stat-hint"/>
                </VBox>
                <VBox styleClass="stat-card,stat-card-green"  HBox.hgrow="ALWAYS" spacing="6">
                    <Label text="Trainers"             styleClass="stat-label"/>
                    <Label fx:id="statTrainers" text="0" styleClass="stat-value"/>
                    <Label text="🏋 Active staff"       styleClass="stat-hint"/>
                </VBox>
                <VBox styleClass="stat-card,stat-card-orange" HBox.hgrow="ALWAYS" spacing="6">
                    <Label text="Workout Plans"        styleClass="stat-label"/>
                    <Label fx:id="statWorkouts" text="0" styleClass="stat-value"/>
                    <Label text="⚡ Assigned plans"     styleClass="stat-hint"/>
                </VBox>
                <VBox styleClass="stat-card,stat-card-purple" HBox.hgrow="ALWAYS" spacing="6">
                    <Label text="Scheduled Sessions"   styleClass="stat-label"/>
                    <Label fx:id="statSchedules" text="0" styleClass="stat-value"/>
                    <Label text="📅 Upcoming"           styleClass="stat-hint"/>
                </VBox>
            </HBox>

            <!--
                CONTENT AREA — FIX:
                VBox.vgrow=ALWAYS ensures this StackPane expands to fill remaining
                vertical space after the header and stats bar.
                Sub-views (Members / Trainers / etc.) are injected here by
                DashboardController.loadView() which also calls
                setMaxWidth/Height(MAX) on the loaded node.
            -->
            <StackPane fx:id="mainContent" VBox.vgrow="ALWAYS" styleClass="content-area"
                       minHeight="200">
                <padding><Insets top="16" bottom="16" left="24" right="24"/></padding>
            </StackPane>
        </VBox>
    </center>
</BorderPane>
