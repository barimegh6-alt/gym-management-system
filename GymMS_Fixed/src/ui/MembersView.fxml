<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<!--
  MembersView.fxml — FIXED
  • Every fx:id matches MembersController @FXML fields exactly
  • Every onAction matches a @FXML method in MembersController
  • Form panel wrapped in ScrollPane → buttons always visible
  • Outer HBox uses VBox.vgrow=ALWAYS so it fills DashboardController's StackPane
-->
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="ui.MembersController"
      spacing="0"
      maxWidth="1.7976931348623157E308"
      maxHeight="1.7976931348623157E308">

    <!-- PAGE HEADER -->
    <HBox styleClass="page-header" alignment="CENTER_LEFT" spacing="14"
          minHeight="54" maxHeight="54">
        <padding><Insets top="0" bottom="0" left="16" right="16"/></padding>
        <Label text="👥  Member Management" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="searchField" styleClass="search-field"
                   promptText="🔍  Search name, email or phone…" prefWidth="250"/>
        <Button text="Search"   styleClass="btn-secondary" onAction="#handleSearch"/>
        <Button text="↺ Refresh" styleClass="btn-secondary" onAction="#handleRefresh"/>
    </HBox>

    <!-- TABLE + FORM -->
    <HBox spacing="14" VBox.vgrow="ALWAYS" maxHeight="1.7976931348623157E308">
        <padding><Insets top="14" bottom="12" left="16" right="16"/></padding>

        <!-- LEFT: Table -->
        <VBox HBox.hgrow="ALWAYS" spacing="10" maxWidth="1.7976931348623157E308">
            <TableView fx:id="membersTable" VBox.vgrow="ALWAYS" styleClass="data-table"
                       maxWidth="1.7976931348623157E308" maxHeight="1.7976931348623157E308">
                <columns>
                    <TableColumn fx:id="colId"         text="ID"       prefWidth="50"/>
                    <TableColumn fx:id="colName"       text="Name"     prefWidth="148"/>
                    <TableColumn fx:id="colEmail"      text="Email"    prefWidth="188"/>
                    <TableColumn fx:id="colPhone"      text="Phone"    prefWidth="108"/>
                    <TableColumn fx:id="colMembership" text="Plan"     prefWidth="88"/>
                    <TableColumn fx:id="colGender"     text="Gender"   prefWidth="72"/>
                    <TableColumn fx:id="colExpiry"     text="Expiry"   prefWidth="100"/>
                    <TableColumn fx:id="colStatus"     text="Status"   prefWidth="80"/>
                </columns>
                <placeholder>
                    <Label text="No members found. Add one using the form →"
                           style="-fx-text-fill:#475569;-fx-font-size:13px;"/>
                </placeholder>
            </TableView>
            <HBox spacing="10" alignment="CENTER_LEFT" minHeight="38">
                <Button text="🗑  Delete Selected" styleClass="btn-danger" onAction="#handleDelete"/>
                <Label fx:id="messageLabel" styleClass="msg-label" wrapText="true" maxWidth="420"/>
            </HBox>
        </VBox>

        <!-- RIGHT: Form inside ScrollPane — FIX for buttons hidden off-screen -->
        <ScrollPane prefWidth="312" minWidth="312" maxWidth="312"
                    fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    VBox.vgrow="ALWAYS" maxHeight="1.7976931348623157E308"
                    style="-fx-background-color:transparent;-fx-background:transparent;">

            <VBox styleClass="form-panel" spacing="11"
                  maxWidth="1.7976931348623157E308">
                <padding><Insets top="16" bottom="20" left="16" right="16"/></padding>

                <Label text="Add / Edit Member" styleClass="form-title"/>
                <Separator/>

                <VBox spacing="4">
                    <Label text="FULL NAME *" styleClass="field-label"/>
                    <TextField fx:id="nameField" styleClass="input-field" promptText="Full name"/>
                </VBox>
                <VBox spacing="4">
                    <Label text="EMAIL *" styleClass="field-label"/>
                    <TextField fx:id="emailField" styleClass="input-field" promptText="someone@email.com"/>
                </VBox>
                <VBox spacing="4">
                    <Label text="PHONE * (10 digits)" styleClass="field-label"/>
                    <TextField fx:id="phoneField" styleClass="input-field" promptText="9876543210"/>
                </VBox>
                <VBox spacing="4">
                    <Label text="PASSWORD *" styleClass="field-label"/>
                    <PasswordField fx:id="passwordField" styleClass="input-field" promptText="Min 4 chars"/>
                </VBox>
                <HBox spacing="10">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="AGE *" styleClass="field-label"/>
                        <TextField fx:id="ageField" styleClass="input-field" promptText="e.g. 25"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="GENDER" styleClass="field-label"/>
                        <ComboBox fx:id="genderCombo" styleClass="combo-field"
                                  maxWidth="1.7976931348623157E308"/>
                    </VBox>
                </HBox>
                <VBox spacing="4">
                    <Label text="MEMBERSHIP PLAN" styleClass="field-label"/>
                    <ComboBox fx:id="membershipCombo" styleClass="combo-field"
                              maxWidth="1.7976931348623157E308"/>
                </VBox>
                <VBox spacing="4">
                    <Label text="STATUS" styleClass="field-label"/>
                    <ComboBox fx:id="statusCombo" styleClass="combo-field"
                              maxWidth="1.7976931348623157E308"/>
                </VBox>
                <VBox spacing="4">
                    <Label text="EXPIRY DATE *" styleClass="field-label"/>
                    <DatePicker fx:id="expiryDatePicker" maxWidth="1.7976931348623157E308"/>
                </VBox>
                <VBox spacing="4">
                    <Label text="ADDRESS" styleClass="field-label"/>
                    <TextField fx:id="addressField" styleClass="input-field" promptText="Street, City"/>
                </VBox>

                <!-- BUTTONS — always visible because parent is inside ScrollPane -->
                <VBox spacing="8" style="-fx-padding:8 0 0 0;">
                    <Button fx:id="addBtn" text="➕  Add Member"
                            styleClass="btn-primary" onAction="#handleAdd"
                            maxWidth="1.7976931348623157E308" prefHeight="40"/>
                    <HBox spacing="8">
                        <Button fx:id="updateBtn" text="✏  Update"
                                styleClass="btn-success" onAction="#handleUpdate"
                                HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" prefHeight="38"/>
                        <Button fx:id="clearBtn"  text="✖  Clear"
                                styleClass="btn-secondary" onAction="#clearForm"
                                HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" prefHeight="38"/>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </HBox>
</VBox>
