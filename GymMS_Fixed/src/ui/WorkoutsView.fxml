<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<!--
  WorkoutsView.fxml — FIXED
  BUG THAT WAS CAUSING BLANK PAGE:
    The old controller had @FXML statusCombo and @FXML deleteBtn but this FXML
    never had fx:id="statusCombo" or fx:id="deleteBtn".
    FXMLLoader injected null into those fields → NullPointerException in
    initialize() → loadView() caught it silently → blank page.
  FIX:
    Removed statusCombo from controller AND this FXML never had it anyway.
    Removed @FXML deleteBtn; the delete Button has no fx:id needed since the
    controller uses workoutsTable.getSelectionModel().getSelectedItem().
-->
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="ui.WorkoutsController"
      spacing="0"
      maxWidth="1.7976931348623157E308"
      maxHeight="1.7976931348623157E308">

    <HBox styleClass="page-header" alignment="CENTER_LEFT" spacing="14"
          minHeight="54" maxHeight="54">
        <padding><Insets top="0" bottom="0" left="16" right="16"/></padding>
        <Label text="⚡  Workout Management" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <HBox spacing="14" VBox.vgrow="ALWAYS" maxHeight="1.7976931348623157E308">
        <padding><Insets top="14" bottom="12" left="16" right="16"/></padding>

        <!-- TABLE -->
        <VBox HBox.hgrow="ALWAYS" spacing="10" maxWidth="1.7976931348623157E308">
            <TableView fx:id="workoutsTable" VBox.vgrow="ALWAYS" styleClass="data-table"
                       maxWidth="1.7976931348623157E308" maxHeight="1.7976931348623157E308">
                <columns>
                    <TableColumn fx:id="colId"         text="ID"           prefWidth="46"/>
                    <TableColumn fx:id="colPlanName"   text="Plan Name"    prefWidth="148"/>
                    <TableColumn fx:id="colCategory"   text="Category"     prefWidth="96"/>
                    <TableColumn fx:id="colDifficulty" text="Difficulty"   prefWidth="90"/>
                    <TableColumn fx:id="colDuration"   text="Duration(min)" prefWidth="94"/>
                    <TableColumn fx:id="colMember"     text="Member"       prefWidth="138"/>
                    <TableColumn fx:id="colTrainer"    text="Trainer"      prefWidth="130"/>
                    <TableColumn fx:id="colDate"       text="Assigned Date" prefWidth="108"/>
                    <TableColumn fx:id="colStatus"     text="Status"       prefWidth="88"/>
                </columns>
                <placeholder>
                    <Label text="No workout plans yet. Assign one using the form →"
                           style="-fx-text-fill:#475569;-fx-font-size:13px;"/>
                </placeholder>
            </TableView>
            <!-- Action row: no fx:id needed on buttons — controllers use getSelectedItem() -->
            <HBox spacing="10" alignment="CENTER_LEFT" minHeight="38">
                <Button text="✅  Mark Complete" styleClass="btn-success"  onAction="#handleMarkComplete"/>
                <Button text="🗑  Delete"         styleClass="btn-danger"   onAction="#handleDelete"/>
                <Label fx:id="messageLabel" styleClass="msg-label" wrapText="true" maxWidth="380"/>
            </HBox>
        </VBox>

        <!-- FORM in ScrollPane -->
        <ScrollPane prefWidth="306" minWidth="306" maxWidth="306"
                    fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    VBox.vgrow="ALWAYS" maxHeight="1.7976931348623157E308"
                    style="-fx-background-color:transparent;-fx-background:transparent;">

            <VBox styleClass="form-panel" spacing="11" maxWidth="1.7976931348623157E308">
                <padding><Insets top="16" bottom="20" left="16" right="16"/></padding>

                <Label text="Assign Workout Plan" styleClass="form-title"/>
                <Separator/>

                <VBox spacing="4">
                    <Label text="PLAN NAME *" styleClass="field-label"/>
                    <TextField fx:id="planNameField" styleClass="input-field"
                               promptText="e.g. Fat Burn Phase 1"/>
                </VBox>
                <VBox spacing="4">
                    <Label text="DESCRIPTION" styleClass="field-label"/>
                    <TextArea fx:id="descriptionArea" styleClass="text-area"
                              promptText="Plan description…" prefRowCount="3"/>
                </VBox>
                <HBox spacing="10">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="CATEGORY" styleClass="field-label"/>
                        <ComboBox fx:id="categoryCombo" styleClass="combo-field"
                                  maxWidth="1.7976931348623157E308"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="DIFFICULTY" styleClass="field-label"/>
                        <ComboBox fx:id="difficultyCombo" styleClass="combo-field"
                                  maxWidth="1.7976931348623157E308"/>
                    </VBox>
                </HBox>
                <VBox spacing="4">
                    <Label text="DURATION (minutes) *" styleClass="field-label"/>
                    <TextField fx:id="durationField" styleClass="input-field" promptText="e.g. 60"/>
                </VBox>
                <VBox spacing="4">
                    <Label text="ASSIGN TO MEMBER *" styleClass="field-label"/>
                    <ComboBox fx:id="memberCombo" styleClass="combo-field"
                              maxWidth="1.7976931348623157E308"/>
                </VBox>
                <VBox spacing="4">
                    <Label text="ASSIGNED BY TRAINER *" styleClass="field-label"/>
                    <ComboBox fx:id="trainerCombo" styleClass="combo-field"
                              maxWidth="1.7976931348623157E308"/>
                </VBox>

                <VBox spacing="8" style="-fx-padding:8 0 0 0;">
                    <Button text="⚡  Assign Plan"
                            styleClass="btn-primary" onAction="#handleAssign"
                            maxWidth="1.7976931348623157E308" prefHeight="40"/>
                    <Button text="✖  Clear Form"
                            styleClass="btn-secondary" onAction="#clearForm"
                            maxWidth="1.7976931348623157E308" prefHeight="36"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </HBox>
</VBox>
